{
  "schemaVersion": 1,
  "id": "advancedspark",
  "version": "${version}",
  "name": "AdvancedSpark",
  "description": "Foundation API and state layer for wathe Spark compatibility.",
  "authors": [
    "Caecorthus"
  ],
  "license": "All-Rights-Reserved",
  "environment": "*",
  "entrypoints": {
    "main": [
      "io.github.caecorthus.advancedspark.AdvancedSpark"
    ],
    "cardinal-components": [
      "io.github.caecorthus.advancedspark.bridge.AdvancedSparkWatheComponents"
    ]
  },
  "mixins": [
    "advancedspark.mixins.json"
  ],
  "custom": {
    "cardinal-components": [
      "wathe:stamina",
      "wathe:veteran",
      "wathe:map_enhancements",
      "wathe:map_voting",
      "advancedspark:ability",
      "advancedspark:config",
      "advancedspark:world_music",
      "advancedspark:hidden_bodies",
      "advancedspark:kill_history"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_dependency}",
    "fabric-api": "*",
    "wathe": ">=1.3.2"
  }
}
